# Database Configuration
DATABASE_URL=postgres://postgres:Sss1234!@localhost:5435/Vicinity_DB
# Server Configuration
PORT=3000
RUST_LOG=info

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
