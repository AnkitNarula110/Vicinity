{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Vicinity Backend",
            "program": "cargo",
            "args": ["run"],
            "cwd": "${workspaceFolder}",
            "sourceLanguages": ["rust"],
            "env": {
                "RUST_BACKTRACE": "1",
                "DATABASE_URL": "postgresql://postgres:password@localhost:5432/vicinity"
            },
            "console": "integratedTerminal"
        },
        {
            "type": "lldb",
            "request": "attach",
            "name": "Attach to Running Process",
            "pid": "${command:pickProcess}",
            "sourceLanguages": ["rust"]
        }
    ]
}